<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="account_activity_report" 
              pageWidth="595" 
              pageHeight="842" 
              columnWidth="555" 
              leftMargin="20" 
              rightMargin="20" 
              topMargin="20" 
              bottomMargin="20">
    
    <parameter name="REPORT_TITLE" class="java.lang.String"/>
    <parameter name="ACCOUNT_HOLDER" class="java.lang.String"/>
    <parameter name="ACCOUNT_NUMBER" class="java.lang.String"/>
    <parameter name="ACCOUNT_NAME" class="java.lang.String"/>
    <parameter name="START_DATE" class="java.lang.String"/>
    <parameter name="END_DATE" class="java.lang.String"/>
    <parameter name="CURRENT_BALANCE" class="java.lang.String"/>
    <parameter name="TOTAL_CREDITS" class="java.lang.String"/>
    <parameter name="TOTAL_DEBITS" class="java.lang.String"/>
    <parameter name="TRANSACTION_COUNT" class="java.lang.String"/>
    
    <field name="transactionId" class="java.lang.String"/>
    <field name="transactionDate" class="java.util.Date"/>
    <field name="transactionType" class="java.lang.String"/>
    <field name="description" class="java.lang.String"/>
    <field name="amount" class="java.lang.Double"/>
    <field name="runningBalance" class="java.lang.Double"/>
    
    <title>
        <band height="120" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="120" backcolor="#003366"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            
            <staticText>
                <reportElement x="10" y="10" width="300" height="40" forecolor="#FFFFFF"/>
                <textElement>
                    <font size="24" isBold="true"/>
                </textElement>
                <text><![CDATA[Altoro Mutual]]></text>
            </staticText>
            
            <textField>
                <reportElement x="10" y="55" width="535" height="25" forecolor="#FFFFFF"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression>
            </textField>
            
            <textField pattern="MMMMM dd, yyyy">
                <reportElement x="400" y="10" width="145" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="10" y="85" width="535" height="20" forecolor="#CCCCCC"/>
                <textElement>
                    <font size="9" isItalic="true"/>
                </textElement>
                <text><![CDATA[Professional Banking Services Since 1997]]></text>
            </staticText>
        </band>
    </title>
    
    <pageHeader>
        <band height="140" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="10" width="555" height="125" backcolor="#F5F5F5"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#CCCCCC"/>
                </graphicElement>
            </rectangle>
            
            <staticText>
                <reportElement x="15" y="20" width="120" height="20"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Account Holder:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="135" y="20" width="200" height="20"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ACCOUNT_HOLDER}]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="15" y="45" width="120" height="20"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Account Number:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="135" y="45" width="200" height="20"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ACCOUNT_NUMBER}]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="15" y="70" width="120" height="20"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Account Type:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="135" y="70" width="200" height="20"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{ACCOUNT_NAME}]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="350" y="20" width="80" height="20"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Period:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="430" y="20" width="110" height="20"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{START_DATE} + " to"]]></textFieldExpression>
            </textField>
            
            <textField>
                <reportElement x="430" y="40" width="110" height="20"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{END_DATE}]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="350" y="70" width="80" height="20"/>
                <textElement>
                    <font size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Balance:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="430" y="70" width="110" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{CURRENT_BALANCE}]]></textFieldExpression>
            </textField>
            
            <line>
                <reportElement x="0" y="105" width="555" height="1"/>
                <graphicElement>
                    <pen lineWidth="2.0" lineColor="#003366"/>
                </graphicElement>
            </line>
            
            <staticText>
                <reportElement x="15" y="110" width="200" height="20"/>
                <textElement>
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Account Summary]]></text>
            </staticText>
        </band>
    </pageHeader>
    
    <columnHeader>
        <band height="100" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="70" backcolor="#E8F4F8"/>
            </rectangle>
            
            <staticText>
                <reportElement x="15" y="10" width="120" height="20"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Credits:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="135" y="10" width="100" height="20" forecolor="#006600"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TOTAL_CREDITS}]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="15" y="35" width="120" height="20"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Debits:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="135" y="35" width="100" height="20" forecolor="#CC0000"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TOTAL_DEBITS}]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="300" y="10" width="150" height="20"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Transactions:]]></text>
            </staticText>
            
            <textField>
                <reportElement x="450" y="10" width="90" height="20"/>
                <textElement textAlignment="Right">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TRANSACTION_COUNT}]]></textFieldExpression>
            </textField>
            
            <rectangle>
                <reportElement x="0" y="80" width="555" height="20" backcolor="#003366"/>
            </rectangle>
            
            <staticText>
                <reportElement x="5" y="80" width="60" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Date]]></text>
            </staticText>
            
            <staticText>
                <reportElement x="70" y="80" width="80" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Transaction ID]]></text>
            </staticText>
            
            <staticText>
                <reportElement x="155" y="80" width="60" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Type]]></text>
            </staticText>
            
            <staticText>
                <reportElement x="220" y="80" width="150" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Description]]></text>
            </staticText>
            
            <staticText>
                <reportElement x="375" y="80" width="80" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Amount]]></text>
            </staticText>
            
            <staticText>
                <reportElement x="460" y="80" width="90" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Balance]]></text>
            </staticText>
        </band>
    </columnHeader>
    
    <detail>
        <band height="25" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="25" backcolor="#FFFFFF">
                    <printWhenExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 == 0)]]></printWhenExpression>
                </reportElement>
            </rectangle>
            
            <rectangle>
                <reportElement x="0" y="0" width="555" height="25" backcolor="#F9F9F9">
                    <printWhenExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 != 0)]]></printWhenExpression>
                </reportElement>
            </rectangle>
            
            <textField pattern="MM/dd/yyyy">
                <reportElement x="5" y="5" width="60" height="15"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{transactionDate}]]></textFieldExpression>
            </textField>
            
            <textField>
                <reportElement x="70" y="5" width="80" height="15"/>
                <textElement textAlignment="Left">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{transactionId}]]></textFieldExpression>
            </textField>
            
            <textField>
                <reportElement x="155" y="5" width="60" height="15"/>
                <textElement textAlignment="Center">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{transactionType}]]></textFieldExpression>
            </textField>
            
            <textField>
                <reportElement x="220" y="5" width="150" height="15"/>
                <textElement textAlignment="Left">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
            </textField>
            
            <textField pattern="$#,##0.00">
                <reportElement x="375" y="5" width="80" height="15">
                    <printWhenExpression><![CDATA["Credit".equals($F{transactionType})]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Right">
                    <font size="8" forecolor="#006600"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
            
            <textField pattern="$#,##0.00">
                <reportElement x="375" y="5" width="80" height="15">
                    <printWhenExpression><![CDATA[!"Credit".equals($F{transactionType})]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Right">
                    <font size="8" forecolor="#CC0000"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
            </textField>
            
            <textField pattern="$#,##0.00">
                <reportElement x="460" y="5" width="90" height="15"/>
                <textElement textAlignment="Right">
                    <font size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{runningBalance}]]></textFieldExpression>
            </textField>
            
            <line>
                <reportElement x="0" y="24" width="555" height="1" forecolor="#DDDDDD"/>
            </line>
        </band>
    </detail>
    
    <pageFooter>
        <band height="50" splitType="Stretch">
            <line>
                <reportElement x="0" y="5" width="555" height="1"/>
            </line>
            
            <staticText>
                <reportElement x="15" y="15" width="300" height="15"/>
                <textElement>
                    <font size="8" isItalic="true"/>
                </textElement>
                <text><![CDATA[This is a confidential document. Please keep it secure.]]></text>
            </staticText>
            
            <textField>
                <reportElement x="450" y="15" width="80" height="15"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of"]]></textFieldExpression>
            </textField>
            
            <textField evaluationTime="Report">
                <reportElement x="530" y="15" width="25" height="15"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[" " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="15" y="30" width="525" height="15"/>
                <textElement textAlignment="Center">
                    <font size="7" isItalic="true"/>
                </textElement>
                <text><![CDATA[Altoro Mutual - Member FDIC - Equal Housing Lender]]></text>
            </staticText>
        </band>
    </pageFooter>
</jasperReport>
